<Window x:Class="MimirDisplay.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display Settings" Height="650" Width="700"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MimirDisplay;component/Resources/DarkComboBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Environment Configuration" 
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <!-- Settings ScrollViewer -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Connection Section -->
                <TextBlock Text="Connection" FontSize="14" FontWeight="Bold" 
                           Foreground="#4EC9B0" Margin="0,0,0,10"/>

                <TextBlock Text="Platform URL" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="PlatformUrlTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="MQTT Broker Host" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="MqttBrokerHostTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="MQTT Broker Port" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="MqttBrokerPortTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="MQTT Username" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="MqttUsernameTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="MQTT Password" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <PasswordBox x:Name="MqttPasswordBox" Padding="8" Margin="0,0,0,15"
                             Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="Heartbeat Interval (seconds)" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="HeartbeatIntervalTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <!-- Identity Section -->
                <TextBlock Text="Identity" FontSize="14" FontWeight="Bold" 
                           Foreground="#4EC9B0" Margin="0,10,0,10"/>

                <TextBlock Text="Display ID (leave empty for auto)" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="DisplayIdTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="Display Name" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="DisplayNameTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="Display Location" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="DisplayLocationTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <!-- Display Section -->
                <TextBlock Text="Display" FontSize="14" FontWeight="Bold" 
                           Foreground="#4EC9B0" Margin="0,10,0,10"/>

                <CheckBox x:Name="FullscreenCheckBox" Content="Start in fullscreen mode" 
                          Margin="0,0,0,15" Foreground="White"/>

                <TextBlock Text="Orientation" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <ComboBox x:Name="OrientationComboBox" Margin="0,0,0,15" Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem Content="landscape"/>
                    <ComboBoxItem Content="portrait_left"/>
                    <ComboBoxItem Content="portrait_right"/>
                </ComboBox>

                <TextBlock Text="Scale Mode" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <ComboBox x:Name="ScaleModeComboBox" Margin="0,0,0,15" Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem Content="fit"/>
                    <ComboBoxItem Content="fill"/>
                </ComboBox>

                <!-- Artwork Overlay Section -->
                <TextBlock Text="Artwork Overlay" FontSize="14" FontWeight="Bold"
                           Foreground="#4EC9B0" Margin="0,10,0,10"/>

                <TextBlock Text="Font Scale (e.g. 1.0 = default, 1.5 = 50% larger)" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="ArtworkFontScaleTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                <TextBlock Text="Position Override" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <ComboBox x:Name="ArtworkPositionComboBox" Margin="0,0,0,15" Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem Content="(use server setting)" Tag=""/>
                    <ComboBoxItem Content="bottom_left"/>
                    <ComboBoxItem Content="bottom_center"/>
                    <ComboBoxItem Content="bottom_right"/>
                    <ComboBoxItem Content="top_left"/>
                    <ComboBoxItem Content="top_center"/>
                    <ComboBoxItem Content="top_right"/>
                </ComboBox>

                <TextBlock Text="Text Wrap Width in pixels (0 = no wrap)" Margin="0,0,0,4" FontSize="12" Foreground="#AAAAAA"/>
                <TextBox x:Name="ArtworkWrapWidthTextBox" Padding="8" Margin="0,0,0,15"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Info Box -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="12" Margin="0,15,0,10" CornerRadius="5">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#AAAAAA">
                <Run Text="Note: Changes require application restart to take effect."/>
                <LineBreak/>
                <Run Text="Settings are saved to .env file in the application directory."/>
            </TextBlock>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ResetButton" Content="Reset to Defaults" Padding="15,8" Margin="0,0,10,0"
                    Click="ResetButton_Click"
                    Background="#3E3E42" Foreground="White" BorderBrush="#555"/>
            <Button x:Name="CancelButton" Content="Cancel" Padding="15,8" Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Background="#3E3E42" Foreground="White" BorderBrush="#555"/>
            <Button x:Name="SaveButton" Content="Save" Padding="15,8"
                    Click="SaveButton_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>

