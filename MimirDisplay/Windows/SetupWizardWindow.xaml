<Window x:Class="MimirDisplay.Windows.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mimir Display — Setup"
        Width="620" Height="540"
        MinWidth="560" MinHeight="480"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MimirDisplay;component/Resources/DarkComboBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <!-- Base text style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Input field style -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="PasswordInputBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,12"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4EC9B0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0E7090"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0E7090"/>
            <Setter Property="Padding" Value="24,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1590B0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Sidebar + step indicator -->
            <RowDefinition Height="*"/>     <!-- Page content -->
            <RowDefinition Height="Auto"/>  <!-- Navigation buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header band ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#252526" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="PageTitleText" FontSize="18" FontWeight="SemiBold"
                               Text="Welcome to Mimir Display"/>
                    <TextBlock x:Name="PageSubtitleText" FontSize="12" Foreground="#888"
                               Margin="0,4,0,0" Text="Let's get your display connected."/>
                </StackPanel>
                <!-- Step dots -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="4,0"
                             Fill="#4EC9B0"/>
                    <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="4,0"
                             Fill="#444"/>
                    <Ellipse x:Name="Dot3" Width="10" Height="10" Margin="4,0"
                             Fill="#444"/>
                    <Ellipse x:Name="Dot4" Width="10" Height="10" Margin="4,0"
                             Fill="#444"/>
                    <Ellipse x:Name="Dot5" Width="10" Height="10" Margin="4,0"
                             Fill="#444"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Page content area ───────────────────────────────────────────── -->
        <Border Grid.Row="1" Padding="28,20">
            <Grid>

                <!-- PAGE 1: Welcome -->
                <StackPanel x:Name="Page1" Visibility="Visible">
                    <TextBlock FontSize="15" TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,20">
                        This wizard will help you configure Mimir Display so it can connect
                        to your Mimir server and start showing content.
                    </TextBlock>

                    <Border Background="#252526" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Margin="0,0,0,8"
                                       Text="You'll need:"/>
                            <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="#CCC" FontSize="13">
                                <Run Text="① "/>
                                <Run FontWeight="SemiBold" Text="Your Mimir server address"/>
                                <Run Text=" — e.g. "/>
                                <Run Foreground="#4EC9B0" FontFamily="Consolas" Text="http://mimir.local:5000"/>
                                <LineBreak/>
                                <Run Text="   (or leave blank to use mDNS auto-discovery)"/>
                                <LineBreak/><LineBreak/>
                                <Run Text="② "/>
                                <Run FontWeight="SemiBold" Text="MQTT broker credentials"/>
                                <Run Text=" — host, port, username &amp; password"/>
                                <LineBreak/>
                                <Run Text="   Found in your Mimir server's Settings → Displays page."/>
                                <LineBreak/><LineBreak/>
                                <Run Text="③ "/>
                                <Run FontWeight="SemiBold" Text="A name and location"/>
                                <Run Text=" for this display (optional)."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap">
                        You can change any of these settings later via the Admin menu → Settings.
                    </TextBlock>
                </StackPanel>

                <!-- PAGE 2: Server Connection -->
                <ScrollViewer x:Name="Page2" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource SectionHeader}" Margin="0,0,0,4"
                                   Text="Platform URL"/>
                        <TextBlock Style="{StaticResource HintText}">
                            Base URL of your Mimir server. Leave blank to use mDNS auto-discovery.
                            Example: http://mimir.local:5000
                        </TextBlock>
                        <TextBox x:Name="PlatformUrlBox" Style="{StaticResource InputBox}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Margin="0,0,0,4"
                                   Text="MQTT Broker"/>
                        <TextBlock Style="{StaticResource HintText}">
                            Your Mimir server also runs an MQTT broker. Find these details
                            on the server's Settings → Displays page.
                        </TextBlock>

                        <TextBlock Style="{StaticResource LabelText}" Text="Broker Host *"/>
                        <TextBox x:Name="MqttHostBox" Style="{StaticResource InputBox}"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="MqttHostError" Foreground="#F87171" FontSize="11"
                                   Margin="0,0,0,10" Visibility="Collapsed"
                                   Text="Broker host is required."/>

                        <TextBlock Style="{StaticResource LabelText}" Text="Broker Port"/>
                        <TextBox x:Name="MqttPortBox" Style="{StaticResource InputBox}"
                                 Margin="0,0,0,12" Text="1883" MaxWidth="120"
                                 HorizontalAlignment="Left"/>

                        <TextBlock Style="{StaticResource LabelText}" Text="Username *"/>
                        <TextBox x:Name="MqttUserBox" Style="{StaticResource InputBox}"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="MqttUserError" Foreground="#F87171" FontSize="11"
                                   Margin="0,0,0,10" Visibility="Collapsed"
                                   Text="Username is required."/>

                        <TextBlock Style="{StaticResource LabelText}" Text="Password *"/>
                        <PasswordBox x:Name="MqttPasswordBox"
                                     Style="{StaticResource PasswordInputBox}"
                                     Margin="0,0,0,4"/>
                        <TextBlock x:Name="MqttPassError" Foreground="#F87171" FontSize="11"
                                   Margin="0,0,0,4" Visibility="Collapsed"
                                   Text="Password is required."/>
                    </StackPanel>
                </ScrollViewer>

                <!-- PAGE 3: Display Identity -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource HintText}" FontSize="13"
                               Foreground="#CCC" Margin="0,0,0,16">
                        Give this display a recognisable name and location so it's easy
                        to find in the Mimir dashboard.
                    </TextBlock>

                    <TextBlock Style="{StaticResource LabelText}" Text="Display Name"/>
                    <TextBox x:Name="DisplayNameBox" Style="{StaticResource InputBox}"
                             Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource HintText}"
                               Text="Shown in the Mimir dashboard. Defaults to the machine hostname."/>

                    <TextBlock Style="{StaticResource LabelText}" Text="Location"/>
                    <TextBox x:Name="DisplayLocationBox" Style="{StaticResource InputBox}"
                             Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource HintText}"
                               Text="Optional — helps you organise multiple displays."/>

                    <TextBlock Style="{StaticResource LabelText}" Text="Display ID (advanced)"/>
                    <TextBox x:Name="DisplayIdBox" Style="{StaticResource InputBox}"
                             Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource HintText}">
                        Only set this if you need a specific ID (e.g. migrating from
                        another client). Leave blank in almost all cases.
                    </TextBlock>
                </StackPanel>

                <!-- PAGE 4: Display Settings -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource HintText}" FontSize="13"
                               Foreground="#CCC" Margin="0,0,0,8">
                        Configure how content is presented on this screen.
                    </TextBlock>

                    <TextBlock Style="{StaticResource LabelText}" Text="Orientation"/>
                    <ComboBox x:Name="OrientationBox" Margin="0,0,0,4"
                              Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="landscape" IsSelected="True"/>
                        <ComboBoxItem Content="portrait_left"/>
                        <ComboBoxItem Content="portrait_right"/>
                    </ComboBox>
                    <TextBlock Style="{StaticResource HintText}"
                               Text="portrait_left / portrait_right rotates the content 90° for vertically-mounted screens."/>

                    <TextBlock Style="{StaticResource LabelText}" Text="Content Scale Mode"/>
                    <ComboBox x:Name="ScaleModeBox" Margin="0,0,0,4"
                              Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="fit" IsSelected="True"/>
                        <ComboBoxItem Content="fill"/>
                    </ComboBox>
                    <TextBlock Style="{StaticResource HintText}">
                        fit = letterbox/pillarbox to preserve aspect ratio.
                        fill = crop to fill the screen.
                    </TextBlock>

                    <CheckBox x:Name="FullscreenBox" Foreground="White" FontSize="13"
                              Margin="0,8,0,4"
                              Content="Start in fullscreen mode"/>
                    <TextBlock Style="{StaticResource HintText}"
                               Text="You can toggle fullscreen at any time with F11."/>
                </StackPanel>

                <!-- PAGE 5: Finish -->
                <StackPanel x:Name="Page5" Visibility="Collapsed">
                    <Border Background="#1A3A2A" BorderBrush="#2A6A4A"
                            BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="20" Foreground="#4EC9B0"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">
                                <Run FontWeight="SemiBold" Text="Setup complete!"/>
                                <LineBreak/>
                                <Run Foreground="#AAA" Text="Your configuration has been saved to .env"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Summary"/>
                    <Border Background="#252526" CornerRadius="6" Padding="14">
                        <TextBlock x:Name="SummaryText" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#CCC" LineHeight="22"/>
                    </Border>

                    <TextBlock Foreground="#888" FontSize="12" TextWrapping="Wrap"
                               Margin="0,16,0,0">
                        Click <Run FontWeight="SemiBold" Foreground="White">Launch</Run>
                        to start the display client. You can adjust settings at any time
                        via Admin menu → Settings.
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Navigation bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#252526" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Step label -->
                <TextBlock x:Name="StepLabel" Grid.Column="0"
                           VerticalAlignment="Center" Foreground="#666" FontSize="12"
                           Text="Step 1 of 5"/>

                <!-- Back -->
                <Button x:Name="BackButton" Grid.Column="2"
                        Style="{StaticResource NavButton}"
                        Margin="0,0,8,0" Content="← Back"
                        IsEnabled="False" Click="BackButton_Click"/>

                <!-- Next / Launch -->
                <Button x:Name="NextButton" Grid.Column="3"
                        Style="{StaticResource PrimaryButton}"
                        Content="Next →" Click="NextButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
