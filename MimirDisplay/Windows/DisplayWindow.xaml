<Window x:Class="MimirDisplay.Windows.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        Title="Mimir Display"
        WindowStyle="SingleBorderWindow"
        WindowState="Normal"
        Width="1280"
        Height="720"
        AllowsTransparency="False"
        Background="Black"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="False">

    <Window.Resources>
        <!-- Dark theme styles for menu items -->
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#656565"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Separator styling -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar (visible only in windowed mode) -->
        <Menu x:Name="AdminMenu" Grid.Row="0" Background="#2D2D30" Foreground="White"
              Visibility="Visible">
            <Menu.Resources>
                <!-- Override system menu colors for dropdowns -->
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#3E3E42"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3E3E42"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ActiveBorderBrushKey}" Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveBorderBrushKey}" Color="#2D2D30"/>
            </Menu.Resources>
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_MQTT Monitor" Click="MenuMqttMonitor_Click"/>
                <Separator/>
                <MenuItem Header="_Clear Cache" Click="MenuClearCache_Click"/>
                <MenuItem Header="View _Logs Folder" Click="MenuViewLogs_Click"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Configuration..." Click="MenuSettings_Click"/>
                <Separator/>
                <MenuItem Header="Reset _Pairing State" Click="MenuResetPairing_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Fullscreen" InputGestureText="F11" Click="MenuToggleFullscreen_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuInfoOverlay" Header="Show _Info Overlay" IsCheckable="True" Click="MenuInfoOverlay_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="MenuAbout_Click"/>
                <Separator/>
                <MenuItem Header="Device ID:" IsEnabled="False"/>
                <MenuItem x:Name="MenuDeviceIdItem" Header="(loading...)" IsEnabled="False"/>
                <MenuItem Header="Connection:" IsEnabled="False"/>
                <MenuItem x:Name="MenuConnectionStatusItem" Header="(loading...)" IsEnabled="False"/>
            </MenuItem>
        </Menu>

        <!-- Content Grid -->
        <Grid x:Name="RootGrid" Grid.Row="1">

        <!-- ── Content image ──────────────────────────────────────────────── -->
        <Image x:Name="ContentImage"
               Stretch="Uniform"
               StretchDirection="Both"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed" />

        <!-- ── Animated GIF rendered via XamlAnimatedGif ─────────────────── -->
        <Image x:Name="AnimatedImage"
               Stretch="Uniform"
               StretchDirection="Both"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed" />

        <!-- ── Splash overlay (shown until content arrives) ──────────────── -->
        <Grid x:Name="SplashOverlay"
              Background="#1A1F22"
              Visibility="Visible">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Image x:Name="LogoImage"
                   Grid.Row="0"
                   Width="160" Height="160"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,24"
                   Stretch="Uniform" />

            <!-- Centre block: pair code + status -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock x:Name="PairCodeLabel"
                           Text="PAIR CODE"
                           FontSize="14"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock x:Name="PairCodeText"
                           Text="------"
                           FontSize="56"
                           FontFamily="Courier New"
                           FontWeight="Bold"
                           Foreground="#00E86A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <TextBlock x:Name="StatusText"
                           Text="Starting…"
                           FontSize="16"
                           FontFamily="Segoe UI"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="480"
                           TextAlignment="Center" />

            </StackPanel>

            <!-- Footer: device info -->
            <StackPanel Grid.Row="2"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0">

                <TextBlock x:Name="DeviceIdText"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Foreground="#555555"
                           HorizontalAlignment="Center" />

            </StackPanel>
        </Grid>

        <!-- ── Info Overlay (toggleable metadata display) ──────────────────────── -->
        <Border x:Name="InfoOverlay"
                Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="16"
                Background="#DD1A1F22"
                BorderBrush="#00E86A"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="FILE INFO"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="#00E86A"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="InfoFileName"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="White"
                           TextWrapping="Wrap"
                           MaxWidth="300"
                           Margin="0,0,0,4"/>

                <TextBlock x:Name="InfoFileSize"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,4"/>

                <TextBlock x:Name="InfoResolution"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,4"/>

                <TextBlock x:Name="InfoFormat"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,4"/>

                <TextBlock x:Name="InfoAnimation"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,4"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="InfoFPS"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,4"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="InfoLastUpdated"
                           FontSize="9"
                           FontFamily="Consolas"
                           Foreground="#666666"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Artwork Overlay (content details a channel attached to the
             render — e.g. mimir-source-metart's title/artist/etc). Shown
             whenever present; not gated behind the Info Overlay toggle.
             Position/content built dynamically in code-behind since the
             field set and corner both vary per channel config. ──────────── -->
        <Border x:Name="ArtworkOverlay"
                Grid.Row="1"
                Margin="24"
                Background="#A6000000"
                CornerRadius="6"
                Padding="20"
                MaxWidth="700"
                Visibility="Collapsed">
            <StackPanel x:Name="ArtworkOverlayPanel"/>
        </Border>

    </Grid>
    </Grid>
</Window>
