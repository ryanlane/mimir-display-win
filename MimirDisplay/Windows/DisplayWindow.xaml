<Window x:Class="MimirDisplay.Windows.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        Title="Mimir Display"
        WindowStyle="SingleBorderWindow"
        WindowState="Normal"
        Width="1280"
        Height="720"
        AllowsTransparency="False"
        Background="Black"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="False">

    <Grid x:Name="RootGrid">

        <!-- ── Content image ──────────────────────────────────────────────── -->
        <Image x:Name="ContentImage"
               Stretch="Uniform"
               StretchDirection="Both"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed" />

        <!-- ── Animated GIF rendered via XamlAnimatedGif ─────────────────── -->
        <Image x:Name="AnimatedImage"
               Stretch="Uniform"
               StretchDirection="Both"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed" />

        <!-- ── Splash overlay (shown until content arrives) ──────────────── -->
        <Grid x:Name="SplashOverlay"
              Background="#1A1F22"
              Visibility="Visible">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Image x:Name="LogoImage"
                   Grid.Row="0"
                   Width="160" Height="160"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,24"
                   Stretch="Uniform" />

            <!-- Centre block: pair code + status -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock x:Name="PairCodeLabel"
                           Text="PAIR CODE"
                           FontSize="14"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock x:Name="PairCodeText"
                           Text="------"
                           FontSize="56"
                           FontFamily="Courier New"
                           FontWeight="Bold"
                           Foreground="#00E86A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <TextBlock x:Name="StatusText"
                           Text="Starting…"
                           FontSize="16"
                           FontFamily="Segoe UI"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="480"
                           TextAlignment="Center" />

            </StackPanel>

            <!-- Footer: device info -->
            <StackPanel Grid.Row="2"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0">

                <TextBlock x:Name="DeviceIdText"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Foreground="#555555"
                           HorizontalAlignment="Center" />

            </StackPanel>
        </Grid>

    </Grid>
</Window>
