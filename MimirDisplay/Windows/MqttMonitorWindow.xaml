<Window x:Class="MimirDisplay.Windows.MqttMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MQTT Monitor" Height="600" Width="900"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="FilterTextBox" Width="200" Padding="4" 
                         TextChanged="FilterTextBox_TextChanged"
                         Background="#3E3E42" Foreground="White" BorderBrush="#555"/>
                <Button x:Name="ClearButton" Content="Clear" Margin="10,0,0,0" Padding="12,4"
                        Click="ClearButton_Click"
                        Background="#0E639C" Foreground="White" BorderThickness="0"/>
                <CheckBox x:Name="AutoScrollCheckBox" Content="Auto-scroll" 
                          IsChecked="True" Margin="15,0,0,0" 
                          Foreground="White" VerticalAlignment="Center"/>
                <CheckBox x:Name="ShowSentCheckBox" Content="Show Sent" 
                          IsChecked="True" Margin="15,0,0,0"
                          Foreground="White" VerticalAlignment="Center"
                          Checked="FilterCheckBox_Changed" Unchecked="FilterCheckBox_Changed"/>
                <CheckBox x:Name="ShowReceivedCheckBox" Content="Show Received" 
                          IsChecked="True" Margin="15,0,0,0"
                          Foreground="White" VerticalAlignment="Center"
                          Checked="FilterCheckBox_Changed" Unchecked="FilterCheckBox_Changed"/>
            </StackPanel>
        </Border>

        <!-- Message List -->
        <ListBox x:Name="MessageListBox" Grid.Row="1"
                 Background="#1E1E1E" Foreground="White"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionMode="Extended">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#3E3E42">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}" 
                                           FontFamily="Consolas" FontSize="11" Foreground="#858585" Width="90"/>
                                <Border Background="{Binding DirectionColor}" CornerRadius="3" Padding="6,2" Margin="4,0">
                                    <TextBlock Text="{Binding Direction}" FontWeight="Bold" FontSize="10"/>
                                </Border>
                                <TextBlock Text="{Binding Topic}" FontFamily="Consolas" FontSize="11" 
                                           Foreground="#4EC9B0" Margin="8,0,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding MessageType, StringFormat='[{0}]'}" 
                                           FontFamily="Consolas" FontSize="10" 
                                           Foreground="#CE9178" Margin="8,0,0,0"
                                           Visibility="{Binding HasMessageType, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding PayloadPreview}" FontFamily="Consolas" FontSize="11" 
                                       Foreground="#D4D4D4" TextWrapping="Wrap" Margin="90,0,0,0"/>
                            <TextBlock Text="{Binding SizeText}" FontFamily="Consolas" FontSize="10" 
                                       Foreground="#858585" Margin="90,2,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTextBlock" Text="Ready" Foreground="#AAAAAA" FontSize="11"/>
                <TextBlock Text=" | " Foreground="#555" Margin="10,0"/>
                <TextBlock x:Name="MessageCountTextBlock" Text="0 messages" Foreground="#AAAAAA" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
