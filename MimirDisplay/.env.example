# Mimir Windows Display Client — .env example
# Copy this to .env and fill in your values.
# Environment variables override appsettings.json.

# ── Connection ─────────────────────────────────────────────────────────────────
# Leave blank to enable mDNS auto-discovery
MIMIR__PLATFORMURL=
MIMIR__MQTTBROKERHOST=
MIMIR__MQTTBROKERPORT=1883
MIMIR__MQTTUSERNAME=
MIMIR__MQTTPASSWORD=
# Heartbeat interval in seconds (affects discovery announcement frequency)
MIMIR__MQTTHEARTBEATINTERVAL=30

# ── Identity ───────────────────────────────────────────────────────────────────
# Leave DISPLAYID blank to derive it from the machine hostname
MIMIR__DISPLAYID=
MIMIR__DISPLAYNAME=Mimir Windows Display
MIMIR__DISPLAYLOCATION=Living Room

# ── Display ────────────────────────────────────────────────────────────────────
# landscape | portrait_left | portrait_right
MIMIR__DISPLAYORIENTATION=landscape
# Comma-separated tags for OTA canary targeting etc.
MIMIR__DISPLAYTAGS=
# Path to startup logo image (PNG/JPEG); defaults to built-in logo
MIMIR__STARTUPLOGOPATH=
# fit | fill
MIMIR__HDMISCALEMODE=fit
MIMIR__HDMIBACKGROUNDCOLOR=#000000

# ── Operational ────────────────────────────────────────────────────────────────
MIMIR__WEBHOOKENABLED=true
MIMIR__WEBHOOKPORT=8081
MIMIR__LOGLEVEL=Information
# Custom directories (defaults to %APPDATA%\MimirDisplay\...)
MIMIR__CACHEDIRECTORY=
MIMIR__STATEDIRECTORY=

# ── Window Mode ──────────────────────────────────────────────────────────────────────
# Set to true to start in fullscreen mode (default: windowed)
# Press F11 to toggle fullscreen at runtime
MIMIR__FULLSCREEN=false
